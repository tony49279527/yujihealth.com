PSI_API_KEY=

# URL-prefix Search Console property.
GSC_SITE_URL=https://yujihealth.com/
GSC_SITEMAP_URL=https://yujihealth.com/sitemap.xml

# Optional for CI or service-account based GSC access.
# The service account must be added to the Search Console property.
GOOGLE_APPLICATION_CREDENTIALS=
GSC_SERVICE_ACCOUNT_JSON=

# Contact form delivery. Keep the public site email as info@yujihealth.com,
# and set INQUIRY_TO in Vercel to the private forwarding inbox.
RESEND_API_KEY=
RESEND_FROM="YUJI Website <info@yujihealth.com>"
PUBLIC_CONTACT_EMAIL=info@yujihealth.com
INQUIRY_TO=
